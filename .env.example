# Template env vars — aman di-commit, isi nilainya di .env.local

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (fallback vision provider)
GOOGLE_API_KEY=

# Integrasi IoT (kamera konveyor / ESP32-CAM → /api/scan/ingest)
# IOT_DEVICE_KEY: kunci yang dikirim perangkat lewat header x-device-key
# IOT_TENANT_ID: bila diisi, hasil scan dari perangkat otomatis disimpan ke koperasi ini
IOT_DEVICE_KEY=
IOT_TENANT_ID=

# Hyperledger Fabric REST API (dari Winata)
HYPERLEDGER_API_URL=

# App
NEXT_PUBLIC_APP_URL=https://arta.vercel.app
